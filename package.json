{
  "author": "Kevin Ross <kevin.ross@alienfast.com>",
  "auto": {
    "canary": {
      "target": "comment"
    },
    "plugins": [
      "npm",
      "all-contributors",
      "first-time-contributor",
      "released"
    ]
  },
  "description": "AlienFast's Biome config.",
  "devDependencies": {
    "@auto-it/all-contributors": "^11.3.6",
    "@auto-it/first-time-contributor": "^11.3.6",
    "@auto-it/released": "^11.3.6",
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1",
    "auto": "^11.3.6",
    "execa": "^9.6.1",
    "markdownlint-cli": "^0.48.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": "./src/base.jsonc",
    "./base": "./src/base.jsonc",
    "./package.json": "./package.json",
    "./react": "./src/react.jsonc"
  },
  "license": "MIT",
  "name": "@alienfast/biome-config",
  "packageManager": "yarn@4.9.4",
  "peerDependencies": {
    "@biomejs/biome": "*"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "repository": "https://github.com/alienfast/biome-config",
  "scripts": {
    "check": "yarn check-biome && yarn check-markdown",
    "check-biome": "biome check --write .",
    "check-markdown": "markdownlint '**/*.md' --fix",
    "clean": "tsx ./scripts/clean.ts",
    "clean:yarn": "tsx ./scripts/clean-yarn.ts",
    "format": "biome format --write .",
    "release": "yarn auto shipit",
    "reset": "tsx ./scripts/reset.ts",
    "test": "yarn check"
  },
  "type": "module",
  "version": "1.0.5"
}
