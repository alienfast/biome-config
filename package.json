{
  "author": "Kevin Ross <kevin.ross@alienfast.com>",
  "auto": {
    "canary": {
      "target": "comment"
    },
    "plugins": [
      [
        "npm",
        {
          "setRcToken": false
        }
      ],
      "all-contributors",
      "first-time-contributor",
      "released"
    ]
  },
  "description": "AlienFast's Biome config.",
  "devDependencies": {
    "@auto-it/all-contributors": "^11.3.6",
    "@auto-it/first-time-contributor": "^11.3.6",
    "@auto-it/released": "^11.3.6",
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1",
    "auto": "^11.3.6",
    "execa": "^9.6.1",
    "markdownlint-cli": "^0.48.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": "./src/base.jsonc",
    "./base": "./src/base.jsonc",
    "./package.json": "./package.json",
    "./react": "./src/react.jsonc"
  },
  "license": "MIT",
  "name": "@alienfast/biome-config",
  "packageManager": "pnpm@10.33.0",
  "peerDependencies": {
    "@biomejs/biome": "*"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": "https://github.com/alienfast/biome-config",
  "scripts": {
    "check": "run-p -c --aggregate-output check-biome check-markdown",
    "check-biome": "biome check --write .",
    "check-markdown": "markdownlint '**/*.md' --fix",
    "clean": "tsx ./scripts/clean.ts",
    "clean:pnpm": "tsx ./scripts/clean-pnpm.ts",
    "format": "biome format --write .",
    "release": "pnpm auto shipit",
    "reset": "tsx ./scripts/reset.ts",
    "test": "pnpm check"
  },
  "type": "module",
  "version": "1.0.5"
}
